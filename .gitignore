# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---------- Environment files (NEVER commit) ----------
.env
.env.local
.env.*.local
.env.production
.env.development
.env.staging
!.env.example
!.env.*.example

# Sensitive tokens / credentials
*token.json*
*credentials.json*
*.pem

# ---------- IDE and editors ----------
.idea/
.vscode/

# ---------- Node / React ----------
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js (unused here but kept)
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
build/
dist/
dist

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store
Thumbs.db

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/

