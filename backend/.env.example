# Example environment file for the backend.
# Copy this to .env and fill in real values. NEVER commit .env to git.

# ---------- MongoDB ----------
# For local development: mongodb://localhost:27017
# For production (MongoDB Atlas): mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URL="mongodb://localhost:27017"

# Name of the MongoDB database
DB_NAME="arroyo_systems"

# ---------- CORS ----------
# Comma-separated list of allowed origins, or "*" for permissive.
# Production example: https://arroyo-systems.com,https://www.arroyo-systems.com
CORS_ORIGINS="*"

# ---------- Auth ----------
# Generate a strong random JWT secret (>= 48 random bytes):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET="change-me-generate-a-strong-random-value"

# Admin user credentials. The backend syncs this password on startup.
ADMIN_USERNAME="arroyo_admin"
ADMIN_PASSWORD="change-me-use-a-strong-password"

# ---------- Privacy / anti-spam ----------
PRIVACY_POLICY_VERSION="v1.0"
# Keep true in production so direct API submissions also require consent.
REQUIRE_PRIVACY_ACCEPTANCE="true"
# Optional Cloudflare Turnstile secret key. If set, /contact requires a valid token.
TURNSTILE_SECRET_KEY=""

# ---------- Abuse protection ----------
RATE_LIMIT_CONTACT_MAX="5"
RATE_LIMIT_CONTACT_WINDOW_SECONDS="60"
# Random secret used to hash IPs before storage.
IP_HASH_SALT="change-me-generate-another-strong-random-value"

# ---------- Email notifications ----------
# Configure these in production to receive an email when a contact request arrives.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM="contact@arroyo-systems.com"
CONTACT_NOTIFICATION_TO="contact@arroyo-systems.com"

# Preferred on Render because it sends over HTTPS instead of SMTP ports.
RESEND_API_KEY=""
RESEND_FROM="Arroyo Systems <notifications@arroyo-systems.com>"
