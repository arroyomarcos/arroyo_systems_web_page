# Example environment file for the backend.
# Copy this to .env and fill in real values. NEVER commit .env to git.

# ---------- MongoDB ----------
# For local development: mongodb://localhost:27017
# For production (MongoDB Atlas): mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URL="mongodb://localhost:27017"

# Name of the MongoDB database
DB_NAME="arroyo_systems"

# ---------- CORS ----------
# Comma-separated list of allowed origins, or "*" for permissive.
# Production example: https://arroyo-systems.com,https://www.arroyo-systems.com
CORS_ORIGINS="*"

# ---------- Auth ----------
# Generate a strong random JWT secret (>= 48 random bytes):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET="change-me-generate-a-strong-random-value"

# Initial admin user credentials — used on first startup only, then persisted.
# To rotate later, delete the admin from the DB and restart the service.
ADMIN_USERNAME="arroyo_admin"
ADMIN_PASSWORD="change-me-use-a-strong-password"
